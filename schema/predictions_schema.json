{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mverab/WorldCupBench/schema/predictions_schema.json",
  "title": "WorldCupBench - FIFA World Cup 2026 Predictions Schema",
  "description": "Schema that defines the structure of predictions generated by each AI model for the FIFA World Cup 2026 (48 teams, 104 matches). Covers group stage, knockout stage, and final standings.",
  "type": "object",
  "required": [
    "model_name",
    "timestamp",
    "group_stage_matches",
    "group_qualifiers",
    "knockout_stage",
    "final_standings"
  ],
  "properties": {
    "model_name": {
      "type": "string",
      "description": "Name of the AI model that generated the predictions (e.g., 'GPT-5.5')."
    },
    "model_id": {
      "type": "string",
      "description": "Model identifier in OpenRouter (e.g., 'openai/gpt-5.5')."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 date and time when the prediction was generated."
    },
    "group_stage_matches": {
      "type": "array",
      "description": "Predictions for the 72 group stage matches.",
      "items": { "$ref": "#/definitions/match_prediction" }
    },
    "group_qualifiers": {
      "type": "object",
      "description": "Teams that qualify for the next round from the group stage.",
      "required": ["first_place", "second_place", "best_third_place"],
      "properties": {
        "first_place": {
          "type": "array",
          "description": "List of 12 teams that finish first in their groups (A-L).",
          "items": { "$ref": "#/definitions/group_position" }
        },
        "second_place": {
          "type": "array",
          "description": "List of 12 teams that finish second in their groups (A-L).",
          "items": { "$ref": "#/definitions/group_position" }
        },
        "best_third_place": {
          "type": "array",
          "description": "The 8 best third-place teams that advance to the Round of 32.",
          "items": { "$ref": "#/definitions/group_position" }
        }
      }
    },
    "knockout_stage": {
      "type": "object",
      "description": "Predictions for the knockout elimination stage.",
      "required": [
        "round_of_32",
        "round_of_16",
        "quarter_finals",
        "semi_finals",
        "third_place_match",
        "final"
      ],
      "properties": {
        "round_of_32": {
          "type": "array",
          "description": "Predictions for the 16 Round of 32 matches.",
          "items": { "$ref": "#/definitions/match_prediction" }
        },
        "round_of_16": {
          "type": "array",
          "description": "Predictions for the 8 Round of 16 matches (Round of 16).",
          "items": { "$ref": "#/definitions/match_prediction" }
        },
        "quarter_finals": {
          "type": "array",
          "description": "Predictions for the 4 Quarter Final matches.",
          "items": { "$ref": "#/definitions/match_prediction" }
        },
        "semi_finals": {
          "type": "array",
          "description": "Predictions for the 2 Semi-Final matches.",
          "items": { "$ref": "#/definitions/match_prediction" }
        },
        "third_place_match": {
          "description": "Prediction for the third place match.",
          "$ref": "#/definitions/match_prediction"
        },
        "final": {
          "description": "Prediction for the Grand Final.",
          "$ref": "#/definitions/match_prediction"
        }
      }
    },
    "final_standings": {
      "type": "object",
      "description": "Final tournament positions predicted by the model.",
      "required": ["champion", "runner_up", "third_place", "fourth_place"],
      "properties": {
        "champion": {
          "type": "string",
          "description": "Champion team (1st place)."
        },
        "runner_up": {
          "type": "string",
          "description": "Runner-up team (2nd place)."
        },
        "third_place": {
          "type": "string",
          "description": "Third place team (3rd)."
        },
        "fourth_place": {
          "type": "string",
          "description": "Fourth place team (4th)."
        }
      }
    }
  },
  "definitions": {
    "match_prediction": {
      "type": "object",
      "description": "Individual match prediction.",
      "required": [
        "match_id",
        "team_a",
        "team_b",
        "predicted_winner",
        "predicted_score",
        "confidence"
      ],
      "properties": {
        "match_id": {
          "type": "string",
          "description": "Unique match identifier (e.g., 'GS-01', 'R32-73', 'FINAL')."
        },
        "stage": {
          "type": "string",
          "description": "Tournament stage this match belongs to.",
          "enum": [
            "group_stage",
            "round_of_32",
            "round_of_16",
            "quarter_finals",
            "semi_finals",
            "third_place_match",
            "final"
          ]
        },
        "group": {
          "type": ["string", "null"],
          "description": "Group letter (A-L) if group stage; null in knockout stages."
        },
        "team_a": {
          "type": "string",
          "description": "First team in the matchup."
        },
        "team_b": {
          "type": "string",
          "description": "Second team in the matchup."
        },
        "predicted_winner": {
          "type": "string",
          "description": "Predicted winning team. In group stage can be 'Draw'."
        },
        "predicted_score": {
          "type": "object",
          "description": "Predicted score.",
          "required": ["team_a", "team_b"],
          "properties": {
            "team_a": {
              "type": "integer",
              "minimum": 0,
              "description": "Predicted goals for team_a."
            },
            "team_b": {
              "type": "integer",
              "minimum": 0,
              "description": "Predicted goals for team_b."
            }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence level of the prediction (0.0 to 1.0)."
        },
        "model_name": {
          "type": "string",
          "description": "Name of the model that generated this match prediction."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 date and time of this match prediction."
        }
      }
    },
    "group_position": {
      "type": "object",
      "description": "Qualified team with its group of origin.",
      "required": ["team", "group"],
      "properties": {
        "team": {
          "type": "string",
          "description": "Name of the qualified team."
        },
        "group": {
          "type": "string",
          "description": "Letter of the group of origin (A-L)."
        }
      }
    }
  }
}
